SubTitle.TextTransparency = 1
SubTitle.Parent = MainFrame

-- 4. Ô nhập Key (Modern TextBox)
local KeyInput = Instance.new("TextBox")
KeyInput.Size = UDim2.new(0, 280, 0, 42)
KeyInput.Position = UDim2.new(0.5, -140, 0, 72)
KeyInput.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
KeyInput.BorderSizePixel = 0
KeyInput.Text = ""
KeyInput.PlaceholderText = "Enter your access key here..."
KeyInput.PlaceholderColor3 = Color3.fromRGB(90, 90, 90)
