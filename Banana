InputCorner.Parent = KeyInput

local InputStroke = Instance.new("UIStroke")
InputStroke.Thickness = 1
InputStroke.Color = Color3.fromRGB(45, 45, 45)
InputStroke.Transparency = 1
InputStroke.Parent = KeyInput

-- Hiệu ứng Focus đổi màu viền khi bấm vào ô nhập Key
KeyInput.Focused:Connect(function()
    TweenService:Create(InputStroke, TweenInfo.new(0.25), {Color = Color3.fromRGB(254, 204, 32)}):Play()
end)
KeyInput.FocusLost:Connect(function()
    TweenService:Create(InputStroke, TweenInfo.new(0.25), {Color = Color3.fromRGB(45, 45, 45)}):Play()
end)

-- 5. Nút bấm Xác nhận (Interactive Submit Button)
local SubmitButton = Instance.new("TextButton")
SubmitButton.Size = UDim2.new(0, 280, 0, 40)
SubmitButton.Position = UDim2.new(0.5, -140, 0, 128)
SubmitButton.BackgroundColor3 = Color3.fromRGB(254, 204, 32)
SubmitButton.BorderSizePixel = 0
SubmitButton.Text = "ACTIVATE NOW"
SubmitButton.TextColor3 = Color3.fromRGB(15, 15, 15)
SubmitButton.Font = Enum.Font.GothamBold
SubmitButton.TextSize = 13
SubmitButton.BackgroundTransparency = 1
SubmitButton.TextTransparency = 1
SubmitButton.Parent = MainFrame

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 8)
ButtonCorner.Parent = SubmitButton

-- Hiệu ứng tương tác rê chuột và nhấn nút
SubmitButton.MouseEnter:Connect(function()
    TweenService:Create(SubmitButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 218, 79)}):Play()
end)
SubmitButton.MouseLeave:Connect(function()
    TweenService:Create(SubmitButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(254, 204, 32)}):Play()
end)
SubmitButton.MouseButton1Down:Connect(function()
    TweenService:Create(SubmitButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(200, 160, 20)}):Play()
end)
SubmitButton.MouseButton1Up:Connect(function()
    TweenService:Create(SubmitButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(255, 218, 79)}):Play()
end)

-- 6. Hiệu ứng Fade-In khi mở UI mượt mà
local function IntroAnimation()
    local tInfo = TweenInfo.new(0.6, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, tInfo, {BackgroundTransparency = 0, Position = UDim2.new(0.5, -170, 0.5, -92)}):Play()
    TweenService:Create(MainStroke, tInfo, {Transparency = 0.3}):Play()
    TweenService:Create(Title, tInfo, {TextTransparency = 0}):Play()
    TweenService:Create(SubTitle, tInfo, {TextTransparency = 0}):Play()
    TweenService:Create(KeyInput, tInfo, {TextTransparency = 0}):Play()
    TweenService:Create(InputStroke, tInfo, {Transparency = 0}):Play()
    TweenService:Create(SubmitButton, tInfo, {BackgroundTransparency = 0, TextTransparency = 0}):Play()
end
task.spawn(IntroAnimation)

-- 7. Hiệu ứng Rung lắc (Shake) khi nhập sai hoặc trống key
local function ShakeTextBox()
    local originalPos = KeyInput.Position
    TweenService:Create(InputStroke, TweenInfo.new(0.1), {Color = Color3.fromRGB(230, 50, 50)}):Play()
    
    for i = 1, 3 do
        KeyInput.Position = originalPos + UDim2.new(0, 6, 0, 0)
        task.wait(0.05)
        KeyInput.Position = originalPos + UDim2.new(0, -6, 0, 0)
        task.wait(0.05)
    end
    KeyInput.Position = originalPos
    TweenService:Create(InputStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(45, 45, 45)}):Play()
end

-- 8. Xử lý Logic cốt lõi & Đóng giao diện không để lại sọc vàng
SubmitButton.MouseButton1Click:Connect(function()
    local enteredKey = KeyInput.Text
    enteredKey = string.gsub(enteredKey, "^%s*(.-)%s*$", "%1") -- Xóa khoảng trắng thừa
    
    if enteredKey ~= "" then
        if enteredKey == "FREE-BANANA2026" then
            getgenv().Key = "b16c0819aabda5d5221bf686"
        else
            getgenv().Key = enteredKey
        end
        
        -- VÔ HIỆU HÓA VIỀN NGAY LẬP TỨC: Sửa triệt để lỗi đường kẻ vàng sót lại
        MainStroke.Enabled = false
        InputStroke.Enabled = false
        
        -- Hiệu ứng co nhỏ và mờ dần khung nền
        local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 340, 0, 0), 
            Position = UDim2.new(0.5, -170, 0.5, 0),
            BackgroundTransparency = 1
        })
        closeTween:Play()
        
        -- Tiến trình tải Script ngầm từ Github
        task.spawn(function()
            local success, err = pcall(function()
                return loadstring(game:HttpGet("https://raw.githubusercontent.com/obiiyeuem/vthangsitink/main/BananaHub.lua"))()
            end)
            
            if success then
                closeTween.Completed:Wait()
                ScreenGui:Destroy() -- Xóa hoàn toàn UI khỏi bộ nhớ game
            else
                -- Phục hồi lại trạng thái UI nếu xảy ra lỗi kết nối
                MainStroke.Enabled = true
                InputStroke.Enabled = true
                MainFrame.Size = UDim2.new(0, 340, 0, 185)
                MainFrame.Position = UDim2.new(0.5, -170, 0.5, -92)
                MainFrame.BackgroundTransparency = 0
                SubmitButton.Text = "CONNECTION ERROR!"
                SubmitButton.BackgroundColor3 = Color3.fromRGB(230, 50, 50)
                SubmitButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                warn("Lỗi tải script BananaHub: " .. tostring(err))
            end
        end)
    else
        -- Báo lỗi trống Key bằng hiệu ứng rung trực quan
        KeyInput.PlaceholderText = "Key cannot be empty!"
        task.spawn(ShakeTextBox)
    end
end)
