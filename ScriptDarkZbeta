            for _, v in pairs(source:GetDescendants()) do
                if v:IsA("BasePart") and v.Name:find("Chest") and v:FindFirstChild("TouchInterest") then
                    table.insert(chests, v)
                end
            end
            if #chests == 0 then return end

            table.sort(chests, function(a,b)
                local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if not root then return false end
                return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
            end)

            local target = chests[1]
            local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if not root then return end

            if _G.Settings.Farming.AutoChestInstant then
                root.CFrame = target.CFrame * CFrame.new(0, 2, 0)
                task.wait(0.05)
                firetouchinterest(root, target, 0)
                task.wait(0.05)
                firetouchinterest(root, target, 1)
            elseif _G.Settings.Farming.AutoChestTween then
                MoveToCFrame(target.CFrame)
                if (target.Position - root.Position).Magnitude < 20 then
                    firetouchinterest(root, target, 0)
                    task.wait(0.05)
                    firetouchinterest(root, target, 1)
                end
            end
        end)
    end
end)

