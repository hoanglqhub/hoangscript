        if ping > 200 then PingLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        else PingLabel.TextColor3 = Color3.fromRGB(255, 170, 0) end
        
        frameCount = 0
        lastUpdate = currentTime
    end
end)

