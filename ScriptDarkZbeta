-- FAST ATTACK MODULE (Từ Bear Hud)
-- ============================================================

local net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local RegisterAttack = net["RE/RegisterAttack"]
local RegisterHit = net["RE/RegisterHit"]

local function AttackEnemy(EnemyHead, Table)
    if EnemyHead then
        RegisterAttack:FireServer(0)
        RegisterAttack:FireServer(1)
        RegisterAttack:FireServer(2)
        RegisterAttack:FireServer(3)
        RegisterHit:FireServer(EnemyHead, Table or {})
    end
end

function AttackNearest()
    local args = { nil, {} }
    
    for _, Enemy in pairs(Workspace.Enemies:GetChildren()) do
        if Enemy:FindFirstChild("HumanoidRootPart") and Enemy:FindFirstChild("Humanoid") and Enemy.Humanoid.Health > 0 then
            local dist = (Enemy.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist <= (_G.Settings.Settings.FarmDistance + 10) then
                if not args[1] then
                    args[1] = Enemy.HumanoidRootPart
                else
                    table.insert(args[2], { Enemy, Enemy.HumanoidRootPart })
                end
            end
        end
    end
    
    if args[1] then
        AttackEnemy(args[1], args[2])
    end
end

function Attack()
    if _G.Settings.Settings.FastAttack then
        AttackNearest()
    else
        pcall(function()
            local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool and (tool.ToolTip == "Melee" or tool.ToolTip == "Sword") then
                AttackNearest()
            end
        end)
    end
end

function CheckNameBoss(bossName)
    for _, v in pairs(Workspace.Enemies:GetChildren()) do
        if v.Name == bossName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            return v
        end
    end
    
    for _, v in pairs(ReplicatedStorage:GetChildren()) do
        if v.Name == bossName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            return v
        end
    end
    
    return nil
end

function CheckItemCount(itemName, itemCount)
    local Inventory = ReplicatedStorage.Remotes.CommF_:InvokeServer("getInventory")
    for i, v in pairs(Inventory) do
        if v.Name == itemName and v.Count >= itemCount then
            return true
        end
    end
    return false
end

