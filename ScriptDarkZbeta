local World1 = false
local World2 = false
local World3 = false

local function detectSea()
    local placeId = game.PlaceId
    
    if placeId == 2753915549 then
        World1 = true
        World2 = false
        World3 = false
        return
    elseif placeId == 4442272183 then
        World1 = false
        World2 = true
        World3 = false
        return
    elseif placeId == 7449423635 then
        World1 = false
        World2 = false
        World3 = true
        return
    end
    
    -- Dự phòng: Kiểm tra bằng tên map
    local ws = Workspace
    if ws:FindFirstChild("Jungle") or ws:FindFirstChild("Desert") or ws:FindFirstChild("Snow") then
        World1 = true
        World2 = false
        World3 = false
    elseif ws:FindFirstChild("Dressrosa") or ws:FindFirstChild("GreenZone") or ws:FindFirstChild("Colosseum") then
        World1 = false
        World2 = true
        World3 = false
    elseif ws:FindFirstChild("Zou") or ws:FindFirstChild("Hydra") or ws:FindFirstChild("Turtle") then
        World1 = false
        World2 = false
        World3 = true
    else
        World1 = true
        World2 = false
        World3 = false
    end
end

detectSea()

