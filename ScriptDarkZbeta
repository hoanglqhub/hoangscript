    if hum then
        hum.WalkSpeed = DefaultSpeed
    end
end

local function EquipWeapon(weaponType)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then
            return
        end
        
        local current = char:FindFirstChildOfClass("Tool")
        if current and current.ToolTip == weaponType then
            return
        end
        
        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.ToolTip == weaponType then
                char.Humanoid:EquipTool(tool)
                break
            end
        end
    end)
end

local function UnEquipWeapon(weapon)
    pcall(function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild(weapon) then
            char[weapon].Parent = LocalPlayer.Backpack
        end
    end)
end

local function MoveToCFrame(targetCFrame)
    if isRespawning then
        return false
    end
    
    pcall(function()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then
            return
        end
        
        local dist = (targetCFrame.Position - root.Position).Magnitude
        if dist < 5 then
            return
        end
        
        local speed = _G.Settings.Settings.TweenSpeed or 350
        local tween = TweenService:Create(root, TweenInfo.new(dist / speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    end)
    return true
end

_G.Topos = MoveToCFrame

local function topos(pos)
    MoveToCFrame(pos)
end

local function InstantTp(p)
    LocalPlayer.Character.HumanoidRootPart.CFrame = p
end

local function BTP(p)
    pcall(function()
        if (p.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude >= 1500 then
            repeat
                wait()
                LocalPlayer.Character.HumanoidRootPart.CFrame = p
                ReplicatedStorage.Remotes.CommF_:InvokeServer("SetSpawnPoint")
                wait()
                LocalPlayer.Character.Head:Destroy()
                LocalPlayer.Character.HumanoidRootPart.CFrame = p
                ReplicatedStorage.Remotes.CommF_:InvokeServer("SetSpawnPoint")
            until (p.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 1500
        end
    end)
end

